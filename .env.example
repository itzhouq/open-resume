# 站点 URL，用于生成 sitemap 和 canonical URL
# 开发环境可以使用 http://localhost:3000
# 生产环境替换为实际域名，如 https://open-resume.itzhouq.cn
NEXT_PUBLIC_SITE_URL=https://open-resume.itzhouq.cn

# Google AdSense 发布商 ID
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=pub-4730905197989922

# 搜索引擎验证码（可选）
# 在各搜索引擎站长平台获取验证码后添加
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
# NEXT_PUBLIC_BAIDU_SITE_VERIFICATION=your-baidu-verification-code
